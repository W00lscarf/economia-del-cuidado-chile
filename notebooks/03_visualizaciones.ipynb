   "source": [
    "# 03 · Visualizaciones publicables\n",
    "\n",
    "Este notebook genera las figuras finales del proyecto, diseñadas para ser compartidas en LinkedIn, GitHub o incluidas en informes. Cada figura viene con su interpretación en una línea."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../..')\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "import seaborn as sns\n",
    "from simel_client import SIMELClient\n",
    "import os\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'font.family': 'sans-serif',\n",
    "    'axes.titlesize': 13,\n",
    "    'axes.labelsize': 11,\n",
    "    'xtick.labelsize': 9,\n",
    "    'ytick.labelsize': 9,\n",
    "})\n",
    "\n",
    "client = SIMELClient()\n",
    "def cargar(ds):\n",
    "    p = f'../data/{ds}.csv'\n",
    "    return pd.read_csv(p) if os.path.exists(p) else client.get(ds)\n",
    "\n",
    "tnr_sexo  = cargar('DF_HRS_TNR_SEXO')\n",
    "tnr_quin  = cargar('DF_HRS_TNR_SEXO_QUINTIL')\n",
    "tnr_edad  = cargar('DF_HRS_TNR_SEXO_EDAD')\n",
    "carga_tot = cargar('DF_HRS_TRAB_TOT_SEXO')\n",
    "fdt       = cargar('DF_FDT_SEXO')\n",
    "brecha    = cargar('DF_BGYMEDIOOCU')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── FIGURA PRINCIPAL: panel de 4 ──────────────────────────────────────────────\n",
    "fig = plt.figure(figsize=(16, 11))\n",
    "gs  = gridspec.GridSpec(2, 2, figure=fig, hspace=0.42, wspace=0.32)\n",
    "\n",
    "ROJO = '#c0392b'; AZUL = '#2e86c1'; MORADO = '#8e44ad'; VERDE = '#27ae60'\n",
    "\n",
    "# ── Panel A: brecha 2015 vs 2023 ──────────────────────────────────────────────\n",
    "ax_a = fig.add_subplot(gs[0, 0])\n",
    "hm   = tnr_sexo[tnr_sexo['SEXO'].isin(['M','F'])]\n",
    "anios = sorted(hm['AÑO'].unique())\n",
    "x, w = np.arange(len(anios)), 0.35\n",
    "for i, (sexo, color, label) in enumerate([('F',ROJO,'Mujeres'),('M',AZUL,'Hombres')]):\n",
    "    vals = hm[hm['SEXO']==sexo].set_index('AÑO')['OBS_VALUE']\n",
    "    b = ax_a.bar(x+i*w, [vals.get(a, np.nan) for a in anios],\n",
    "                 w, color=color, label=label, edgecolor='white', alpha=0.9)\n",
    "    ax_a.bar_label(b, fmt='%.2fh', padding=3, fontsize=8)\n",
    "ax_a.set_xticks(x+w/2); ax_a.set_xticklabels(anios)\n",
    "ax_a.set_ylabel('Horas diarias'); ax_a.legend(fontsize=8)\n",
    "ax_a.set_title('A · Trabajo no remunerado por sexo', fontweight='bold')\n",
    "sns.despine(ax=ax_a)\n",
    "\n",
    "# ── Panel B: carga por quintil (año más reciente, mujeres) ────────────────────\n",
    "ax_b = fig.add_subplot(gs[0, 1])\n",
    "quin_col = next((c for c in tnr_quin.columns if 'QUIN' in c.upper()), tnr_quin.columns[4])\n",
    "quin_f = tnr_quin[(tnr_quin['SEXO']=='F') & (tnr_quin[quin_col]!='_T')]\n",
    "if len(quin_f):\n",
    "    for anio, grupo in quin_f.groupby('AÑO'):\n",
    "        g = grupo.sort_values(quin_col)\n",
    "        ls = '-' if anio == quin_f['AÑO'].max() else '--'\n",
    "        alpha = 1.0 if anio == quin_f['AÑO'].max() else 0.45\n",
    "        ax_b.plot(range(len(g)), g['OBS_VALUE'], 'o'+ls,\n",
    "                  color=ROJO, alpha=alpha, linewidth=2, label=str(anio))\n",
    "    ax_b.set_xticks(range(len(g)))\n",
    "    ax_b.set_xticklabels(g[quin_col].values)\n",
    "    ax_b.set_xlabel('Quintil (Q1=más pobre)')\n",
    "    ax_b.set_ylabel('Horas diarias')\n",
    "    ax_b.legend(title='Año', fontsize=8)\n",
    "ax_b.set_title('B · Carga de cuidados femenina por quintil', fontweight='bold')\n",
    "sns.despine(ax=ax_b)\n",
    "\n",
    "# ── Panel C: ciclo de vida (edad) ─────────────────────────────────────────────\n",
    "ax_c = fig.add_subplot(gs[1, 0])\n",
    "edad_col = next((c for c in tnr_edad.columns if 'EDAD' in c.upper()), tnr_edad.columns[4])\n",
    "e_max = tnr_edad['AÑO'].max()\n",
    "for sexo, color, label in [('F',ROJO,'Mujeres'),('M',AZUL,'Hombres')]:\n",
    "    sub = tnr_edad[(tnr_edad['SEXO']==sexo)&(tnr_edad['AÑO']==e_max)&(tnr_edad[edad_col]!='_T')].sort_values(edad_col)\n",
    "    ax_c.plot(range(len(sub)), sub['OBS_VALUE'], 'o-', color=color, label=label, linewidth=2)\n",
    "    ax_c.set_xticks(range(len(sub)))\n",
    "    ax_c.set_xticklabels(sub[edad_col].values, rotation=30, ha='right')\n",
    "ax_c.set_ylabel('Horas diarias'); ax_c.legend(fontsize=8)\n",
    "ax_c.set_title(f'C · Ciclo de vida del cuidado — {e_max}', fontweight='bold')\n",
    "sns.despine(ax=ax_c)\n",
    "\n",
    "# ── Panel D: participación laboral femenina regional ─────────────────────────\n",
    "ax_d = fig.add_subplot(gs[1, 1])\n",
    "fdt_max = fdt['AÑO'].max()\n",
    "fdt_r = fdt[(fdt['AÑO']==fdt_max)&(fdt['AREA_REF']!='_T')&(fdt['SEXO'].isin(['M','F']))]\n",
    "if len(fdt_r):\n",
    "    pivot_fdt = fdt_r.pivot_table(index='REGION', columns='SEXO', values='OBS_VALUE')\n",
    "    if 'F' in pivot_fdt and 'M' in pivot_fdt:\n",
    "        pivot_fdt['ratio'] = pivot_fdt['F'] / pivot_fdt['M']\n",
    "        pivot_fdt = pivot_fdt.sort_values('ratio')\n",
    "        colores_d = [ROJO if r<0.75 else '#e67e22' if r<0.85 else VERDE for r in pivot_fdt['ratio']]\n",
    "        ax_d.barh(pivot_fdt.index, pivot_fdt['ratio'], color=colores_d, edgecolor='white')\n",
    "        ax_d.axvline(1, color='gray', linestyle='--', linewidth=1)\n",
    "        ax_d.set_xlabel('Ratio FDT Mujeres/Hombres')\n",
    "ax_d.set_title(f'D · Participación laboral por región — {fdt_max}', fontweight='bold')\n",
    "sns.despine(ax=ax_d)\n",
    "\n",
    "fig.suptitle('Economía del Cuidado en Chile — Resumen visual',\n",
    "             fontsize=15, fontweight='bold', y=1.01)\n",
    "\n",
    "# Nota de fuente\n",
    "fig.text(0.5, -0.01, 'Fuente: SIMEL-INE Chile — ENUT 2015/2023 · ENE trimestral · ESI anual\\n'\n",
    "         'API: https://sdmx.ine.gob.cl · Elaboración propia',\n",
    "         ha='center', fontsize=8, color='gray')\n",
    "\n",
    "plt.savefig('../outputs/figures/panel_resumen_cuidado.png', dpi=180, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Figura guardada en outputs/figures/panel_resumen_cuidado.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Conclusiones del proyecto\n",
    "\n",
    "### Lo que muestran los datos\n",
    "\n",
    "1. **La brecha de cuidados se redujo entre 2015 y 2023**, pero sigue siendo de aproximadamente 1.7x: las mujeres dedican casi el doble de tiempo que los hombres al trabajo no remunerado.\n",
    "\n",
    "2. **La reducción fue asimétrica**: bajaron las horas de las mujeres (por mayor participación laboral), no subieron significativamente las de los hombres. No hay evidencia de redistribución real de tareas domésticas.\n",
    "\n",
    "3. **La carga es regresiva por ingresos**: las mujeres de quintiles bajos cargan más en términos absolutos y tienen menor capacidad de externalizar esas tareas. Una política de cuidado universal reduciría simultáneamente desigualdad de género y desigualdad socioeconómica.\n",
    "\n",
    "4. **El \"doble turno\" es real**: las mujeres que trabajan de forma remunerada no dejan el trabajo doméstico — lo hacen además. Esto limita su disponibilidad para cargos de mayor responsabilidad y explica parte de la brecha salarial.\n",
    "\n",
    "5. **La brecha etaria tiene su peak en 25-44 años**, el tramo de mayor productividad laboral. Esto genera una huella permanente en la acumulación de experiencia y contribuciones previsionales.\n",
    "\n",
    "### Limitaciones metodológicas\n",
    "\n",
    "- La ENUT solo tiene dos puntos temporales (2015 y 2023): no permite análisis de tendencia continua.\n",
    "- No capta cuidado simultáneo (actividad secundaria), lo que subestima la carga real.\n",
    "- Los datos de participación laboral (FDT) son de mayor frecuencia pero no cruzan directamente con los de cuidado.\n",
    "\n",
    "### Próximos pasos posibles\n",
    "\n",
    "- Cruzar con datos CASEN para análisis de pobreza de tiempo por quintil.\n",
    "- Valorización macroeconómica del TNR como % del PIB (metodología de cuentas satélite).\n",
    "- Comparación con otros países de la región usando datos OIT."
   ]
  }
